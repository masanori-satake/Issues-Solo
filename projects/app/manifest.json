{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.12.1",
  "default_locale": "en",
  "description": "__MSG_extDescription__",
  "permissions": [
    "sidePanel",
    "tabs",
    "storage",
    "scripting",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://*.atlassian.net/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.atlassian.net/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "__MSG_actionTitle__"
  }
}
